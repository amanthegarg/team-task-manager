# ─────────────────────────────────────────────
# Team Task Manager — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection string (provided by Railway PostgreSQL plugin)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# JWT secret — use a long random string (at least 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_jwt_secret_here

# JWT expiry duration
JWT_EXPIRES_IN=7d

# Node environment: development | production
NODE_ENV=development

# Port the Express server listens on (Railway sets this automatically)
PORT=5000

# Frontend origin for CORS (used in development)
CLIENT_ORIGIN=http://localhost:5173
